DATABASE_URL="postgresql://user:password@localhost:5432/wanosend?schema=public"
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
DEFAULT_FROM_EMAIL="onboarding@resend.dev"
DEFAULT_FROM_NAME="Wanosend"
APP_URL="http://localhost:3000"

# Cloudinary — image hosting for email banners. Set CLOUDINARY_URL, OR the
# three discrete vars below. When unset, image hosting is disabled.
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="wanosend"

# Secret protecting the background send worker (/api/cron/send). Vercel Cron
# sends this automatically when set. Use a long random string.
CRON_SECRET=""
